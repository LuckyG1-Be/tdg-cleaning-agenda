# Neon Postgres connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Simple admin login
ADMIN_USERNAME="tdg"
# Generate with: npm run hash:password -- <YOUR_PASSWORD>
ADMIN_PASSWORD_HASH=""

# For signing the session cookie (random long string)
JWT_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_STRING"

# Used for logout redirect in production (optional; local defaults to http://localhost:3000)
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
